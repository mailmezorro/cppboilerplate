digraph "mylib" {
node [
  fontsize = "12"
];
    "node0" [ label = "mylib", shape = octagon ];
    "node1" [ label = "mylib_app", shape = egg ];
    "node1" -> "node0" [ style = dotted ] // mylib_app -> mylib
    "node2" [ label = "mylib_tests", shape = egg ];
    "node2" -> "node0" [ style = dotted ] // mylib_tests -> mylib
}
